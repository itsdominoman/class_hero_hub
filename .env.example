APP_NAME=Class Hero Hub
APP_ENV=development
# Accepted values: development, test, production

PUBLIC_APP_URL=https://familyherohub.com
API_BASE_URL=https://familyherohub.com

DATABASE_URL=sqlite:////app/data/family_hero_hub.sqlite
POSTGRES_DB=family_hero_hub
POSTGRES_USER=familyhero
POSTGRES_PASSWORD=replace_with_generated_password
MIGRATION_DATABASE_URL=postgresql+psycopg://familyhero:replace_with_generated_password@postgres:5432/family_hero_hub

GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_REDIRECT_URI=https://familyherohub.com/api/auth/google/callback

JWT_SECRET=generate_a_long_random_secret_at_least_32_chars
SESSION_SECRET=generate_a_long_random_secret_at_least_32_chars

PLATFORM_ADMIN_EMAILS=
TRUSTED_PROXY_IPS=127.0.0.1,::1
# CHH→FHH integration is dark by default. If enabled, use a random secret of at least 32 characters.
FHH_INTEGRATION_ENABLED=false
FHH_INTEGRATION_SERVICE_TOKEN=
# Optional private/mesh source IPs or CIDRs, e.g. 10.250.50.1
FHH_INTEGRATION_ALLOWED_IPS=
# Separate shared secret used only to verify short-lived FHH messaging actor assertions.
FHH_MESSAGING_ASSERTION_SECRET=
FHH_MESSAGING_ASSERTION_ISSUER=fhh-school-messaging
FHH_MESSAGING_ASSERTION_AUDIENCE=chh-school-messaging
MESSAGING_ENABLED=false
# Slice 10 scheduler only recalculates durable notification eligibility. It does
# not contact a push provider; the Slice 11 dispatcher will consume pending rows.
MESSAGING_NOTIFICATION_SCHEDULER_ENABLED=false
MESSAGING_NOTIFICATION_DISPATCH_ENABLED=false
MESSAGING_NOTIFICATION_SCHEDULER_POLL_SECONDS=15
MESSAGING_NOTIFICATION_SCHEDULER_BATCH_SIZE=50
MESSAGING_NOTIFICATION_SCHEDULER_LEASE_SECONDS=60
MESSAGING_NOTIFICATION_RECHECK_SECONDS=300
MESSAGING_NOTIFICATION_RETRY_BASE_SECONDS=30
MESSAGING_NOTIFICATION_RETRY_MAX_SECONDS=3600
MESSAGING_NOTIFICATION_MAX_ATTEMPTS=10
MESSAGING_PRODUCTION_WORKER_ENABLED=false
MESSAGING_PRODUCTION_WORKER_POLL_SECONDS=15
MESSAGING_PRODUCTION_JOB_LEASE_SECONDS=300
MESSAGE_MEDIA_ARCHIVE_DIR=/app/data/message_media_archive
BACKUP_HEALTH_MARKER_FILE=/app/data/backup-health.json
# Keep these sender-only values in an untracked .env.push file loaded only by
# notification_scheduler. Never add service-account JSON to the shared .env.
FIREBASE_SERVICE_ACCOUNT_JSON=
CHH_ANDROID_PACKAGE=com.classherohub.app
FHH_NOTIFICATION_BRIDGE_URL=https://dev.familyherohub.com/api/integrations/chh/school-message-notifications
FHH_NOTIFICATION_SERVICE_TOKEN=
FHH_NOTIFICATION_HMAC_SECRET=
FHH_NOTIFICATION_TIMEOUT_SECONDS=5
QA_BLOCKED_HOSTNAMES=familyherohub.com,www.familyherohub.com
CORS_ORIGINS=https://familyherohub.com,http://localhost:5173,http://localhost:8000

QA_LOGIN_ENABLED=false
QA_LOGIN_TOKEN=
QA_LOGIN_EMAIL=qa-parent@dev.familyherohub.com
QA_LOGIN_NAME=QA Parent
QA_CHILD_LOGIN_ENABLED=false
QA_CHILD_LOGIN_TOKEN=

# SMTP settings for outgoing mail (staff invites, etc.)
# Prefer port 587 with STARTTLS. If the mail server requires implicit SSL
# instead, set SMTP_PORT=465 (STARTTLS is skipped automatically for 465).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Class Hero Hub
SMTP_USE_TLS=true
