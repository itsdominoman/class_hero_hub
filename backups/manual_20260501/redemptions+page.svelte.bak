<script lang="ts">
  import { onMount } from 'svelte';
  import { api } from '$lib/api';
  import { Check, X, Clock, MessageSquare } from 'lucide-svelte';

  let redemptions = $state([]);
  let loading = $state(true);
  let error = $state(null);

  async function loadRedemptions() {
    try {
      loading = true;
      redemptions = await api.get('/redemptions');
    } catch (e) {
      error = e.message;
    } finally {
      loading = false;
    }
  }

  onMount(loadRedemptions);

  async function processRedemption(id, action) {
    try {
      await api.post(`/redemptions/${id}/${action}`, {});
      await loadRedemptions();
    } catch (e) {
      alert(e.message);
    }
  }
</script>

<div class="max-w-4xl mx-auto px-4 py-12">
  <h1 class="text-3xl font-black text-slate-900 mb-8">Redemption Requests</h1>

  {#if loading}
    <div class="flex justify-center py-12">
      <div class="animate-spin w-10 h-10 border-4 border-hero border-t-transparent rounded-full"></div>
    </div>
  {:else if error}
    <div class="card bg-red-50 p-6 text-red-600 font-bold">{error}</div>
  {:else if redemptions.length === 0}
    <div class="card p-12 text-center text-slate-400 font-bold uppercase tracking-widest bg-slate-50 border-dashed border-2">
      No requests found
    </div>
  {:else}
    <div class="space-y-6">
      {#each redemptions as r}
        <div class="card p-6 flex flex-col md:flex-row md:items-center gap-6 {r.status === 'pending' ? 'border-l-4 border-hero' : 'opacity-60'}">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-black uppercase tracking-widest text-hero">{r.status}</span>
              <span class="text-slate-300">•</span>
              <span class="text-sm font-bold text-slate-500">{new Date(r.created_at).toLocaleDateString()}</span>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-1">{r.title}</h3>
            <p class="text-slate-600 mb-4">{r.description}</p>
            <div class="flex items-center gap-2 text-hero font-black">
              <Clock size={16} /> {r.points} Hero Points
            </div>
          </div>

          {#if r.status === 'pending'}
            <div class="flex gap-2">
              <button 
                onclick={() => processRedemption(r.id, 'approve')}
                class="flex-1 md:flex-none px-6 py-2 bg-savings text-white rounded-xl font-bold hover:bg-savings-dark transition-all flex items-center justify-center gap-2"
              >
                <Check size={18} /> Approve
              </button>
              <button 
                onclick={() => processRedemption(r.id, 'reject')}
                class="flex-1 md:flex-none px-6 py-2 bg-penalty text-white rounded-xl font-bold hover:bg-penalty-dark transition-all flex items-center justify-center gap-2"
              >
                <X size={18} /> Reject
              </button>
            </div>
          {:else}
            <div class="text-right">
              {#if r.parent_note}
                <p class="text-xs font-bold text-slate-400 uppercase mb-1">Parent Note</p>
                <p class="text-sm italic text-slate-500 max-w-[200px]">{r.parent_note}</p>
              {/if}
            </div>
          {/if}
        </div>
      {each}
    </div>
  {/if}
</div>
