{
  "name": "family-hero-hub-frontend",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "bash ./scripts/run-playwright-e2e.sh",
    "test:e2e:public": "bash ./scripts/run-playwright-e2e.sh public",
    "test:e2e:auth": "bash ./scripts/run-playwright-e2e.sh auth",
    "test:e2e:visual": "bash ./scripts/run-playwright-e2e.sh visual",
    "test:e2e:local": "playwright test",
    "test:e2e:stateful": "bash ./scripts/run-playwright-e2e.sh stateful",
    "test:e2e:stateful:local": "playwright test --config=playwright.stateful.config.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:i18n": "node scripts/check-i18n-parity.mjs",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.7",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^3.2.0",
    "@sveltejs/adapter-static": "^3.0.1",
    "@sveltejs/kit": "^2.5.10",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "@types/eslint": "^8.56.7",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.40.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-svelte": "^3.2.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "svelte": "^5.0.0-next.260",
    "svelte-check": "^3.6.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.0.0",
    "vite": "^5.2.11"
  },
  "overrides": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "cookie": "^0.7.2",
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@capacitor/camera": "^7.0.5",
    "@capacitor/core": "^7.6.7",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.378.0",
    "qrcode": "^1.5.4",
    "svelte-i18n": "^4.0.1",
    "tailwind-merge": "^2.3.0"
  }
}
